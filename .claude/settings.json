{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "env -u GIT_DIR -u GIT_WORK_TREE python3 \"$CLAUDE_PROJECT_DIR/src/hooks/dep_guard.py\"",
            "timeout": 10
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "env -u GIT_DIR -u GIT_WORK_TREE python3 \"$CLAUDE_PROJECT_DIR/src/hooks/user-prompt-submit.py\"",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "env -u GIT_DIR -u GIT_WORK_TREE python3 \"$CLAUDE_PROJECT_DIR/src/hooks/post-tool-use.py\"",
            "timeout": 30
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/session-start-guardrails.sh\"",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "nohup \"$CLAUDE_PROJECT_DIR\"/scripts/setup-agent-base.sh </dev/null >/dev/null 2>&1 &"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "env -u GIT_DIR -u GIT_WORK_TREE python3 \"$CLAUDE_PROJECT_DIR/src/hooks/stop.py\"",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "echo '{\"cwd\": \"'\"$(pwd)\"'\", \"notification_type\": \"stop\"}' | ~/.claude/notify.sh"
          }
        ]
      }
    ]
  }
}
